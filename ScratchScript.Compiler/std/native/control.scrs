namespace "scratch/control";

enum StopTarget {
    All = "all",
    ThisScript = "this script",
    OtherScripts = "other scripts"
}

@inline function wait(seconds: number)
{
    return __raw("control_wait", {inputs: {DURATION: number}});
}

@inline function waitUntil(condition: boolean)
{
    return __raw("control_wait_until", {inputs: {CONDITION: condition}});
}

@inline function stop(target: StopTarget)
{
    return __raw("control_stop", {fields: {STOP_OPTION: target.value}});
}